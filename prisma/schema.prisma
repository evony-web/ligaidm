generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// IDM LEAGUE - DANCE TOURNAMENT PLATFORM SCHEMA
// ============================================

model Player {
  id        String   @id @default(cuid())
  name      String
  gamertag  String   @unique
  division  String   // "male" | "female"
  tier      String   @default("B") // "S" | "A" | "B"
  avatar    String?
  points    Int      @default(0)
  totalWins Int      @default(0)
  totalMvp  Int      @default(0)
  streak    Int      @default(0) // current win streak
  maxStreak Int      @default(0)
  matches   Int      @default(0)
  isActive  Boolean  @default(true)

  // Registration fields
  phone              String?  // WhatsApp number (optional)
  city               String   @default("") // Kota (required at registration)
  joki               String?  // Name of joki if player is played by someone else (optional)
  registrationStatus String   @default("approved") // "pending" | "approved" | "rejected"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamPlayers    TeamPlayer[]
  participations Participation[]
  mvpMatches     Match[]       @relation("MvpPlayer")
  clubMembers    ClubMember[]

  @@index([division])
  @@index([division, isActive])
}

model Season {
  id        String   @id @default(cuid())
  name      String
  number    Int
  division  String   // "male" | "female"
  status    String   @default("active") // "active" | "completed" | "upcoming"
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournaments Tournament[]
  donations   Donation[]
  clubs       Club[]
  leagueMatches LeagueMatch[]
  playoffMatches PlayoffMatch[]

  @@index([division, status])
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  weekNumber  Int
  division    String   // "male" | "female"
  status      String   @default("setup") // "setup" | "registration" | "approval" | "team_generation" | "bracket_generation" | "main_event" | "finalization" | "completed"
  format      String   @default("single_elimination") // "single_elimination" | "double_elimination" | "group_stage"
  defaultMatchFormat String @default("BO1") // "BO1" | "BO3" | "BO5" — default, can be overridden per match
  seasonId    String
  prizePool   Int      @default(0) // total prize pool in IDR
  bpm         Int?
  location    String?
  scheduledAt DateTime?
  finalizedAt DateTime? // when admin finalized prizes/MVP
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  season        Season         @relation(fields: [seasonId], references: [id])
  teams         Team[]
  matches       Match[]
  participations Participation[]
  prizes        TournamentPrize[]
  donations     Donation[]

  @@unique([weekNumber, division, seasonId])
  @@index([division, seasonId])
}

model Team {
  id           String  @id @default(cuid())
  name         String
  tournamentId String
  power        Int     @default(0)
  isWinner     Boolean @default(false)
  rank         Int?

  tournament  Tournament  @relation(fields: [tournamentId], references: [id])
  teamPlayers TeamPlayer[]
  matchAsTeam1 Match[]    @relation("Team1")
  matchAsTeam2 Match[]    @relation("Team2")
  matchesWon  Match[]    @relation("MatchWinner")
  matchesLost Match[]    @relation("MatchLoser")
}

model TeamPlayer {
  id       String @id @default(cuid())
  teamId   String
  playerId String

  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([teamId, playerId])
}

model Match {
  id           String   @id @default(cuid())
  tournamentId String
  round        Int      @default(1)    // Round number (1=first round, 2=second, etc.)
  matchNumber  Int      @default(1)    // Position within round for display order
  bracket      String   @default("upper") // "upper" | "lower" | "grand_final" | "group"
  groupLabel   String?                 // "A" | "B" | "C" | "D" (only for group stage)
  format       String   @default("BO1") // "BO1" | "BO3" | "BO5" — per match override

  // Team references — nullable because bracket slots may be TBD until previous match completes
  team1Id      String?
  team2Id      String?
  score1       Int?
  score2       Int?
  status       String   @default("pending") // "pending" | "ready" | "live" | "completed"
  winnerId     String?  // Team ID of winner (set when match completed)
  loserId      String?  // Team ID of loser (for DE lower bracket feed)
  mvpPlayerId  String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  team1      Team?      @relation("Team1", fields: [team1Id], references: [id])
  team2      Team?      @relation("Team2", fields: [team2Id], references: [id])
  winner     Team?      @relation("MatchWinner", fields: [winnerId], references: [id])
  loser      Team?      @relation("MatchLoser", fields: [loserId], references: [id])
  mvpPlayer  Player?    @relation("MvpPlayer", fields: [mvpPlayerId], references: [id])

  @@index([tournamentId])
  @@index([status])
  @@index([tournamentId, bracket, round])
}

model Participation {
  id           String   @id @default(cuid())
  playerId     String
  tournamentId String
  status       String   @default("registered") // "registered" | "approved" | "rejected" | "assigned"
  tierOverride String?  // Tier assigned by admin during approval (overrides Player.tier for team generation)
  pointsEarned Int      @default(0)
  isMvp        Boolean  @default(false)
  isWinner     Boolean  @default(false)
  createdAt    DateTime @default(now())

  player     Player     @relation(fields: [playerId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([playerId, tournamentId])

  @@index([tournamentId, status])
  @@index([isMvp])
}

model Donation {
  id           String   @id @default(cuid())
  donorName    String
  amount       Int      // in IDR
  message      String?
  type         String   @default("weekly") // "weekly" | "season"
  tournamentId String?
  seasonId     String?
  createdAt    DateTime @default(now())

  tournament Tournament? @relation(fields: [tournamentId], references: [id])
  season     Season?     @relation(fields: [seasonId], references: [id])

  @@index([tournamentId])
  @@index([seasonId])
}

// ============================================
// IDM LEAGUE - TOURNAMENT PRIZE DISTRIBUTION
// ============================================

model TournamentPrize {
  id           String   @id @default(cuid())
  tournamentId String
  label        String   // "Juara 1" | "Juara 2" | "Juara 3" | "MVP" | custom label
  position     Int      @default(0) // Sort order (1=first)
  prizeAmount  Int      @default(0) // in IDR
  pointsPerPlayer Int   @default(0) // Auto-calculated: prizeAmount / recipientCount
  recipientCount  Int   @default(1) // 1 for MVP, 3 for team (members per team)
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
}

// ============================================
// IDM LEAGUE - ADMIN AUTHENTICATION
// ============================================

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("admin") // "super_admin" | "admin"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// IDM LEAGUE - CLUB & LEAGUE SYSTEM
// ============================================

model Club {
  id       String  @id @default(cuid())
  name     String
  division String  // "male" | "female"
  logo     String?
  seasonId String
  wins     Int     @default(0)
  losses   Int     @default(0)
  points   Int     @default(0)
  gameDiff Int     @default(0)

  season      Season        @relation(fields: [seasonId], references: [id])
  members     ClubMember[]
  homeMatches LeagueMatch[] @relation("HomeClub")
  awayMatches LeagueMatch[] @relation("AwayClub")
  playoffHome PlayoffMatch[] @relation("PlayoffHome")
  playoffAway PlayoffMatch[] @relation("PlayoffAway")

  @@unique([name, seasonId])
  @@index([seasonId])
  @@index([division])
}

model ClubMember {
  id       String @id @default(cuid())
  clubId   String
  playerId String
  role     String @default("member") // "captain" | "member"

  club    Club    @relation(fields: [clubId], references: [id])
  player  Player  @relation(fields: [playerId], references: [id])

  @@unique([clubId, playerId])

  @@index([playerId])
}

model LeagueMatch {
  id       String  @id @default(cuid())
  seasonId String
  club1Id  String
  club2Id  String
  score1   Int?
  score2   Int?
  week     Int
  status   String  @default("upcoming") // "upcoming" | "live" | "completed"
  format   String  @default("BO3") // "BO3" | "BO5"

  season Season @relation(fields: [seasonId], references: [id])
  club1  Club   @relation("HomeClub", fields: [club1Id], references: [id])
  club2  Club   @relation("AwayClub", fields: [club2Id], references: [id])

  @@index([seasonId, status])
  @@index([seasonId, week])
}

model PlayoffMatch {
  id       String  @id @default(cuid())
  seasonId String
  club1Id  String
  club2Id  String
  score1   Int?
  score2   Int?
  round    String  // "semifinal1" | "semifinal2" | "grand_final"
  status   String  @default("upcoming") // "upcoming" | "live" | "completed"
  format   String  @default("BO5")

  season Season @relation(fields: [seasonId], references: [id])
  club1  Club   @relation("PlayoffHome", fields: [club1Id], references: [id])
  club2  Club   @relation("PlayoffAway", fields: [club2Id], references: [id])

  @@index([seasonId])
  @@index([status])
}

// ============================================
// IDM LEAGUE - CMS (CONTENT MANAGEMENT SYSTEM)
// ============================================

model CmsSection {
  id          String   @id @default(cuid())
  slug        String   @unique // "header" | "hero" | "champions" | "mvp" | "clubs" | "gallery" | "sawer" | "cta" | "footer"
  title       String   @default("")
  subtitle    String   @default("")
  description String   @default("")
  bannerUrl   String?  // Section background/banner image
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards CmsCard[]
}

model CmsCard {
  id          String   @id @default(cuid())
  sectionId   String
  title       String   @default("")
  subtitle    String   @default("")
  description String   @default("")
  imageUrl    String?  // Card image
  linkUrl     String?  // Optional link
  tag         String?  // Badge tag text
  tagColor    String?  // Badge tag color
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  section CmsSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model CmsSetting {
  id    String @id @default(cuid())
  key   String @unique // "logo_url" | "site_title" | "hero_tagline" etc.
  value String @default("")
  type  String @default("text") // "text" | "image" | "json"
  updatedAt DateTime @updatedAt
}
